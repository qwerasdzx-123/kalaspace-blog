---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav class="main-nav">
		<div class="nav-brand">
			<a href="/" class="brand-link">
				<span class="brand-icon">🛡️</span>
				<span class="brand-name">{SITE_TITLE}</span>
			</a>
		</div>
		<div class="nav-links">
			<div class="nav-group">
				<span class="nav-group-label">漏洞库</span>
				<a href="/vul" class="nav-link active">总览</a>
				<a href="/vul/cms" class="nav-link">CMS漏洞</a>
				<a href="/vul/editor" class="nav-link">编辑器漏洞</a>
				<a href="/vul/middleware" class="nav-link">中间件/框架</a>
				<a href="/vul/product" class="nav-link">产品/工具</a>
				<a href="/vul/system" class="nav-link">系统漏洞</a>
				<a href="/vul/iot" class="nav-link">IoT/设备</a>
			</div>
			<div class="nav-group">
				<span class="nav-group-label">知识库</span>
				<a href="/kb" class="nav-link">总览</a>
				<a href="/kb/web-security" class="nav-link">Web安全</a>
				<a href="/kb/penetration" class="nav-link">渗透测试</a>
				<a href="/kb/reverse" class="nav-link">逆向工程</a>
				<a href="/kb/ctf" class="nav-link">CTF</a>
				<a href="/kb/cheatsheet" class="nav-link">速查表</a>
			</div>
			<div class="nav-group">
				<a href="/about" class="nav-link">关于</a>
			</div>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0;
		background: var(--bg-header);
		border-bottom: 1px solid var(--border-color);
		position: sticky;
		top: 0;
		z-index: 100;
		backdrop-filter: blur(10px);
	}
	.main-nav {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 1.5em;
		height: 64px;
	}
	.nav-brand {
		flex-shrink: 0;
	}
	.brand-link {
		display: flex;
		align-items: center;
		gap: 0.5em;
		text-decoration: none;
		color: rgb(var(--black));
		font-weight: 700;
		font-size: 1.1em;
	}
	.brand-icon {
		font-size: 1.4em;
	}
	.brand-name {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.5em;
		overflow-x: auto;
	}
	.nav-group {
		display: flex;
		align-items: center;
		gap: 0.2em;
		padding: 0 0.5em;
		border-right: 1px solid var(--border-color);
	}
	.nav-group:last-child {
		border-right: none;
	}
	.nav-group-label {
		font-size: 0.7em;
		color: rgb(var(--gray));
		padding: 0 0.5em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		white-space: nowrap;
	}
	.nav-link {
		padding: 0.4em 0.8em;
		color: rgb(var(--gray));
		border-radius: 6px;
		text-decoration: none;
		font-size: 0.88em;
		white-space: nowrap;
		transition: all 0.2s ease;
	}
	.nav-link:hover {
		color: var(--accent);
		background: rgba(0, 212, 170, 0.08);
	}
	.nav-link.active {
		color: var(--accent);
	}
	@media (max-width: 900px) {
		.nav-group-label { display: none; }
		.nav-group { border-right: none; gap: 0.1em; }
	}
	@media (max-width: 600px) {
		.main-nav { flex-direction: column; height: auto; padding: 0.5em 1em; gap: 0.5em; }
		.nav-links { flex-wrap: wrap; justify-content: center; }
		header { position: relative; }
	}
</style>
