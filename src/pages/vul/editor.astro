---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
const editorVulns = [
	// KindEditor
	{name:"KindEditor 3.4.2/3.5.5 列目录漏洞",sev:"low",desc:"文件遍历漏洞，可浏览服务器文件结构",tags:["目录遍历","信息泄露"]},
	{name:"KindEditor 3.2.1 任意文件上传",sev:"high",desc:"upload_json.*文件未授权访问",tags:["文件上传","未授权"]},
	{name:"KindEditor 3.5.2-4.1 上传修改Getshell",sev:"high",desc:"上传图片格式绕过",tags:["Getshell","文件上传"]},
	{name:"KindEditor <=4.1.5 任意文件上传",sev:"high",desc:"file_manager_json.*遍历+上传",tags:["文件上传","目录遍历"]},
	{name:"KindEditor <=4.1.11 上传漏洞",sev:"high",desc:"上传路径和类型未校验",tags:["文件上传"]},
	{name:"KindEditor 解析漏洞上传",sev:"high",desc:"Apache/iis解析漏洞绕过",tags:["解析漏洞","文件上传"]},
	// Ueditor
	{name:"Ueditor .NET 1.4.3.3 任意文件上传",sev:"high",desc:"controller.ashx未授权访问上传",tags:["文件上传","未授权"]},
	{name:"Ueditor SSRF漏洞",sev:"high",desc:"remoteimage参数SSRF内网探测",tags:["SSRF"]},
	{name:"Ueditor 反射型XSS",sev:"low",desc:"image markedup输出未转义",tags:["XSS"]},
	{name:"Ueditor 存储型XSS",sev:"medium",desc:"图片上传XSS存储",tags:["XSS","存储型"]},
	// FCKeditor
	{name:"FCKeditor 编辑器渗透思路",sev:"medium",desc:"版本探测+上传绕过Getshell",tags:["Getshell","文件上传"]},
	{name:"FCKeditor 2.4.3 文件上传",sev:"high",desc:"多种上传绕过方式获取shell",tags:["Getshell","文件上传"]},
	// EWebEditor
	{name:"EWebEditor 任意文件上传",sev:"high",desc:"upload.asp未授权访问",tags:["文件上传","未授权"]},
	{name:"EWebEditor 目录遍历",sev:"medium",desc:"Style.xml遍历文件",tags:["目录遍历","文件读取"]},
	// CKEditor
	{name:"CKEditor 4.0.1 多个安全漏洞",sev:"medium",desc:"路径遍历+XSS组合",tags:["路径遍历","XSS"]},
	// CuteEditor
	{name:"CuteEditor ASP.NET 解析漏洞",sev:"high",desc:"上传asa/cer文件解析Getshell",tags:["解析漏洞","Getshell"]},
	{name:"CuteEditor 本地文件包含",sev:"high",desc:"Admin_Pictures.aspx LFI",tags:["文件包含","LFI"]},
	// Freetextbox
	{name:"Freetextbox Asp.net解析漏洞",sev:"high",desc:"上传cer文件解析Getshell",tags:["解析漏洞","Getshell"]},
	{name:"Freetextbox 目录遍历",sev:"medium",desc:"目录穿越读取任意文件",tags:["目录遍历"]},
	// Others
	{name:"南方数据southidceditor 注入漏洞",sev:"medium",desc:"编辑器SQL注入",tags:["SQL注入"]},
	{name:"Webhtmleditor 解析漏洞",sev:"high",desc:"IIS6.0解析漏洞绕过",tags:["解析漏洞"]},
	{name:"CKFinder 1.4.3 漏洞",sev:"medium",desc:"验证绕过+文件上传",tags:["文件上传","验证绕过"]},
	{name:"MSNeditor 任意文件上传",sev:"high",desc:"upload.aspx未授权上传",tags:["文件上传","未授权"]},
];
---

<!doctype html>
<html lang="zh-CN">
<head>
	<BaseHead title="编辑器漏洞 - " + SITE_TITLE} description="KindEditor/Ueditor/FCKeditor/EWebEditor/CKEditor等编辑器漏洞情报" />
</head>
<style>
	.hero { padding: 3em 0 2em; border-bottom: 1px solid var(--border-color); margin-bottom: 2em; }
	.hero h1 { color: var(--accent); font-size: 2em; }
	.hero p { color: rgb(var(--gray)); }
	.count-badge { display: inline-block; padding: 2px 12px; border-radius: 20px; background: rgba(0,212,170,0.1); border: 1px solid rgba(0,212,170,0.3); color: var(--accent); font-size: 0.85em; margin-bottom: 1em; }
	.vul-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 0.8em; }
	.vul-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 10px; padding: 1em 1.2em; transition: all 0.2s; }
	.vul-card:hover { border-color: var(--accent); }
	.vul-card-header { display: flex; align-items: center; gap: 0.5em; margin-bottom: 0.4em; flex-wrap: wrap; }
	.vul-name { font-weight: 700; font-size: 0.92em; color: rgb(var(--black)); flex: 1; }
	.vul-desc { font-size: 0.8em; color: rgb(var(--gray)); margin: 0; line-height: 1.5; }
	.vul-tags { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 0.5em; }
	.sev-bar { width: 4px; border-radius: 2px; align-self: stretch; flex-shrink: 0; }
	.bar-critical { background: var(--accent-red); }
	.bar-high { background: #ffa502; }
	.bar-medium { background: var(--accent-yellow); }
	.bar-low { background: var(--accent); }
</style>
<body>
	<Header />
	<main>
		<div class="hero">
			<span class="count-badge">📝 编辑器漏洞 · 20+ 款</span>
			<h1>📝 编辑器漏洞</h1>
			<p>收录 KindEditor、Ueditor、FCKeditor、EWebEditor、CKEditor、CuteEditor 等主流 Web 编辑器的漏洞情报，主要包括任意文件上传、目录遍历和XSS类型漏洞。</p>
		</div>
		<div class="vul-grid">
			{editorVulns.map(v => (
				<div class="vul-card">
					<div class="vul-card-header">
						<div class={`sev-bar bar-${v.sev}`}></div>
						<div class="vul-name">{v.name}</div>
						<span class={`tag tag-${v.sev}`}>{v.sev === 'critical' ? '严重' : v.sev === 'high' ? '高危' : v.sev === 'medium' ? '中危' : '低危'}</span>
					</div>
					<p class="vul-desc">{v.desc}</p>
					<div class="vul-tags">{v.tags.map(t => <span class="tag tag-info">{t}</span>)}</div>
				</div>
			))}
		</div>
	</main>
	<Footer />
</body>
</html>
