---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
<head>
	<BaseHead title="关于 - " + SITE_TITLE} description="关于KalaSpace Sec安全知识库" />
	<style>
		main {
			max-width: 720px;
			margin: 0 auto;
			padding: 3em 1em;
		}
		.hero {
			text-align: center;
			padding: 2em 0 3em;
		}
		.hero h1 {
			font-size: 2.5em;
			margin-bottom: 0.3em;
			color: var(--accent);
		}
		.hero p {
			color: rgb(var(--gray));
			font-size: 1.1em;
		}
		.card {
			background: var(--bg-card);
			border: 1px solid var(--border-color);
			border-radius: 12px;
			padding: 1.5em;
			margin-bottom: 1.5em;
		}
		.card h2 {
			color: var(--accent);
			font-size: 1.2em;
			margin-top: 0;
			margin-bottom: 0.8em;
			padding-bottom: 0.5em;
			border-bottom: 1px solid var(--border-color);
		}
		.card p, .card li {
			color: rgb(var(--gray-dark));
			line-height: 1.8;
		}
		.card ul {
			padding-left: 1.5em;
		}
		.card li {
			margin-bottom: 0.5em;
		}
		.card a {
			color: var(--accent);
		}
		.card a:hover {
			color: var(--accent-yellow);
		}
		.tag-cloud {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5em;
		}
		.tag-item {
			background: var(--bg-card);
			border: 1px solid var(--border-color);
			padding: 4px 12px;
			border-radius: 20px;
			font-size: 0.85em;
			color: rgb(var(--gray-dark));
		}
		.notice {
			background: rgba(255, 71, 87, 0.06);
			border: 1px solid rgba(255, 71, 87, 0.2);
			border-radius: 8px;
			padding: 1em 1.5em;
			color: var(--accent-red);
			font-size: 0.88em;
		}
	</style>
</head>
<body>
	<Fragment slot="Header" />
	<main>
		<div class="hero">
			<h1>🛡️ 关于本站</h1>
			<p>KalaSpace Sec · 网络安全知识库 & 漏洞情报中心</p>
		</div>

		<div class="card">
			<h2>📖 关于我们</h2>
			<p>
				KalaSpace Sec 是一个开放的网络安全知识分享平台，致力于整理和分享网络安全研究笔记、漏洞情报、渗透测试技术、逆向工程知识等。
				内容覆盖 Web 安全、渗透测试、逆向分析、CTF 竞赛等多个领域。
			</p>
			<p>
				本平台基于 <a href="https://astro.build/" target="_blank">Astro</a> 框架构建，
				部署于 <a href="https://workers.cloudflare.com/" target="_blank">Cloudflare Workers</a>，
				所有内容开源可见于 <a href="https://github.com/qwerasdzx-123/kalaspace-blog" target="_blank">GitHub</a>。
			</p>
		</div>

		<div class="card">
			<h2>📚 内容分类</h2>
			<ul>
				<li><strong>🔴 漏洞库</strong>：收录国内外主流系统的漏洞情报，包含 CVE 编号、影响版本、POC/EXP 及修复建议</li>
				<li><strong>📚 知识库</strong>：Web 安全漏洞原理、渗透测试方法、逆向分析技术、CTF 解题思路</li>
				<li><strong>📋 速查表</strong>：XSS/SQL注入/端口/WAF绕过等实用快速参考</li>
				<li><strong>🏆 CTF笔记</strong>：各类CTF题目writeup和解题技巧</li>
			</ul>
		</div>

		<div class="card">
			<h2>🛠️ 技术栈</h2>
			<div class="tag-cloud">
				<span class="tag-item">Astro</span>
				<span class="tag-item">Cloudflare Workers</span>
				<span class="tag-item">MDX</span>
				<span class="tag-item">GitHub</span>
				<span class="tag-item">Giscus</span>
				<span class="tag-item">Kali Linux</span>
				<span class="tag-item">BurpSuite</span>
				<span class="tag-item">IDA Pro</span>
				<span class="tag-item">Frida</span>
				<span class="tag-item">MobSF</span>
			</div>
		</div>

		<div class="card">
			<h2>🔗 相关链接</h2>
			<ul>
				<li>🌐 GitHub：<a href="https://github.com/qwerasdzx-123" target="_blank">@qwerasdzx-123</a></li>
				<li>📦 本博客源码：<a href="https://github.com/qwerasdzx-123/kalaspace-blog" target="_blank">kalaspace-blog</a></li>
				<li>💬 评论系统：<a href="https://giscus.app" target="_blank">Giscus (GitHub Discussions)</a></li>
			</ul>
		</div>

		<div class="notice">
			⚠️ <strong>免责声明：</strong>本网站所有内容仅供安全研究与学习使用。请遵守当地法律法规，未经明确授权，禁止对任何系统进行渗透测试或漏洞利用。所有漏洞信息均来自公开渠道整理，不针对任何特定目标。
		</div>

	</main>
	<Footer />
</body>
</html>
